# Copie para .env.local (não commitar). Em produção o build injeta NEXT_PUBLIC_* via Docker/Jenkins.
#
# Dev (API em outra porta):
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#
# HML/Prod com HTTPS no navegador: a URL da API precisa ser HTTPS no mesmo esquema
# da página, OU use proxy no mesmo domínio:
#   NEXT_PUBLIC_API_URL=same-origin
#   (Nginx/Traefik: location /api → proxy_pass http://backend:3001/api)
#
# HML tudo HTTP (site abre em http://): pode usar URL absoluta HTTP do API:
#   NEXT_PUBLIC_API_URL=http://api-hml.seudominio.com
#
# Produção com API em outro host HTTPS:
#   NEXT_PUBLIC_API_URL=https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:3001
