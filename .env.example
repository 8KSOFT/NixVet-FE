# Copie para .env.local (não commitar). Em produção o Jenkins injeta no build (NEXT_PUBLIC_*).
#
# API (obrigatório no build)
#   NEXT_PUBLIC_API_URL=http://localhost:8537
#   ou https://api.seudominio.com  |  same-origin (proxy /api no Nginx)
#
# Meta — Pixel / anúncios (opcional; só efeito se você injetar o script no layout)
NEXT_PUBLIC_META_PIXEL_ID=
# URL pública do site (útil para links absolutos / OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Domínio raiz para subdomínios de tenant (PRD: nixvetapp.com.br)
# HML usa nixvet.8ksoft.com — não é subdomínio de tenant; campo de código fica editável.
NEXT_PUBLIC_ROOT_DOMAIN=nixvetapp.com.br

# Hosts da app que nunca disparam detecção de tenant (separados por vírgula)
# NEXT_PUBLIC_APP_HOSTS=nixvet.8ksoft.com,nixvet-api.8ksoft.com

NEXT_PUBLIC_API_URL=http://localhost:8537
